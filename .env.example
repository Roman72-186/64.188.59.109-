# ============================================================================
#  Шаблон SSH-доступа к VPS. Скопировать в .env и заполнить реальными значениями.
#  Реальный .env — в .gitignore, в репозиторий не попадает.
# ============================================================================

SSH_HOST=
SSH_PORT=22
SSH_USER=root
SSH_PASSWORD=

# Пин host key сервера (SHA256). Узнать: plink -batch <user>@<host> (покажет fingerprint)
# или ssh-keyscan <host> | ssh-keygen -lf -
SSH_HOSTKEY_SHA256=

# Приватные ключи для входа по ключу (публичные добавить в authorized_keys на сервере)
SSH_KEY_OPENSSH=~/.ssh/tbank_proxy_deploy
SSH_KEY_RSA_PEM=~/.ssh/tbank_proxy_deploy_rsa

DEPLOY_PATH=/opt/tbank_proxy
SERVER_OS=
SERVER_PYTHON=
